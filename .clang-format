---
BasedOnStyle: Google

# Project preference: 4 spaces, while staying close to Google defaults.
IndentWidth: 4
TabWidth: 4
UseTab: Never

# Common modern C++ preference (Google default is typically 80).
ColumnLimit: 100

SortIncludes: true
IncludeBlocks: Regroup

PointerAlignment: Left
DerivePointerAlignment: false

# Avoid one-line `for (...) body;` loops (helps readability in examples).
AllowShortLoopsOnASingleLine: false

# Always use braces for control statements (if/for/while/do), even for single statements.
InsertBraces: true
...
